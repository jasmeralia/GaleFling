# Twitter (OAuth 1.0a)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# Bluesky
BLUESKY_IDENTIFIER=
BLUESKY_APP_PASSWORD=

# Instagram (Graph API — graph.instagram.com)
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=

# Instagram AWS S3 media staging (required for image/video/carousel posts)
# The bucket must be public-read with a lifecycle policy to expire staged objects.
INSTAGRAM_AWS_ACCESS_KEY_ID=
INSTAGRAM_AWS_SECRET_ACCESS_KEY=
INSTAGRAM_AWS_REGION=us-west-2
INSTAGRAM_AWS_BUCKET=

# WebView platforms — GaleFling data directory
# Export via Settings > Advanced > Export Test Config, or set manually
# to the GaleFling AppData directory (e.g. C:\Users\you\AppData\Roaming\GaleFling)
GALEFLING_DATA_DIR=

# OnlyFans (WebView)
# If the session cookie has expired the tests will log in automatically.
# ONLYFANS_TOTP_SECRET is the base32-encoded TOTP secret from your authenticator
# app (required only if 2FA is enabled on the account).
ONLYFANS_EMAIL=
ONLYFANS_PASSWORD=
ONLYFANS_TOTP_SECRET=

# Fansly (WebView)
# If the session cookie has expired the tests will log in automatically.
FANSLY_EMAIL=
FANSLY_PASSWORD=

# FetLife (WebView)
# If the session cookie has expired the tests will log in automatically.
FETLIFE_EMAIL=
FETLIFE_PASSWORD=

# Threads (WebView)
# If the session cookie has expired the tests will log in automatically
# via threads.net/login using the Instagram/Meta username and password below.
THREADS_USERNAME=
THREADS_PASSWORD=

# Snapchat (WebView)
# If the session cookie has expired the tests will log in automatically
# via accounts.snapchat.com using the username/email and password below.
SNAPCHAT_USERNAME=
SNAPCHAT_PASSWORD=
